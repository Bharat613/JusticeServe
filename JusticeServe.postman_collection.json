{
  "info": {
    "name": "JusticeServe - Legal Case Management API",
    "_postman_id": "justiceserve-2025",
    "description": "Complete API collection for JusticeServe Legal Case & Court Management System.\n\nBase URL: http://localhost:8080\n\nAuthentication: JWT Bearer Token\nAfter login, copy the token from the response and set it in the collection variable 'jwt_token'.\n\nCollection Variables:\n- base_url: http://localhost:8080\n- jwt_token: (set after login)\n- citizen_id: (set after creating citizen)\n- case_id: (set after filing case)\n- hearing_id: (set after scheduling hearing)\n- judgment_id: (set after recording judgment)\n- user_id: (set after register/login)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "jwt_token", "value": "", "type": "string" },
    { "key": "user_id", "value": "1", "type": "string" },
    { "key": "citizen_id", "value": "1", "type": "string" },
    { "key": "case_id", "value": "1", "type": "string" },
    { "key": "hearing_id", "value": "1", "type": "string" },
    { "key": "judgment_id", "value": "1", "type": "string" },
    { "key": "order_id", "value": "1", "type": "string" },
    { "key": "doc_id", "value": "1", "type": "string" },
    { "key": "notification_id", "value": "1", "type": "string" },
    { "key": "compliance_id", "value": "1", "type": "string" },
    { "key": "audit_id", "value": "1", "type": "string" },
    { "key": "report_id", "value": "1", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "01 - Authentication",
      "description": "Public endpoints - no token required. Register users and login to get JWT token.",
      "item": [
        {
          "name": "Register - Admin",
          "event": [{ "listen": "test", "script": { "exec": ["if(pm.response.code === 200){ pm.collectionVariables.set('jwt_token', pm.response.json().token); pm.collectionVariables.set('user_id', pm.response.json().userId); }"], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"System Administrator\",\n  \"email\": \"admin@justiceserve.gov\",\n  \"password\": \"Admin@123\",\n  \"role\": \"ADMIN\",\n  \"phone\": \"9876543210\"\n}" }
