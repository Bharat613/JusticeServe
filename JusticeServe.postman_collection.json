    {
      "name": "02 - User Management (Admin)",
      "description": "Admin-only user management endpoints. Manage all system users, roles, and account status.",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api","users"] }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["api","users","{{user_id}}"] }
          }
        },
        {
          "name": "Get Users By Role - JUDGE",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/users/role/JUDGE", "host": ["{{base_url}}"], "path": ["api","users","role","JUDGE"] }
          }
        },
        {
          "name": "Get Users By Role - LAWYER",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/users/role/LAWYER", "host": ["{{base_url}}"], "path": ["api","users","role","LAWYER"] }
          }
        },
        {
          "name": "Get Users By Role - CITIZEN",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/users/role/CITIZEN", "host": ["{{base_url}}"], "path": ["api","users","role","CITIZEN"] }
          }
        },
        {
          "name": "Update User Status - INACTIVE",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}/status?status=INACTIVE", "host": ["{{base_url}}"], "path": ["api","users","{{user_id}}","status"], "query": [{"key":"status","value":"INACTIVE"}] }
          }
        },
        {
          "name": "Update User Status - ACTIVE",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}/status?status=ACTIVE", "host": ["{{base_url}}"], "path": ["api","users","{{user_id}}","status"], "query": [{"key":"status","value":"ACTIVE"}] }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}", "host": ["{{base_url}}"], "path": ["api","users","{{user_id}}"] }
          }
        }
      ]
    },
