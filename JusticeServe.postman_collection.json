    {
      "name": "05 - Hearing Scheduling",
      "description": "Schedule and manage court hearings. Record proceedings during hearings.",
      "item": [
        {
          "name": "Schedule Hearing (Clerk/Judge)",
          "event": [{ "listen": "test", "script": { "exec": ["if(pm.response.code === 200){ pm.collectionVariables.set('hearing_id', pm.response.json().hearingId); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/hearings", "host": ["{{base_url}}"], "path": ["api","hearings"] },
            "body": { "mode": "raw", "raw": "{\n  \"caseId\": 1,\n  \"judgeId\": 4,\n  \"date\": \"2025-02-15\",\n  \"time\": \"10:30:00\"\n}" }
          }
        },
        {
          "name": "Schedule Second Hearing (Adjourned)",
          "request": {
            "method": "POST",
