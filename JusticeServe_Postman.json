{
  "info": {
    "name": "JusticeServe API — Complete Collection",
    "_postman_id": "justiceserve-2025",
    "description": "All API endpoints for JusticeServe Legal Case & Court Management System.\n\nBase URL: http://localhost:8080\n\nSetup:\n1. Run the backend: mvn spring-boot:run\n2. Insert admin via SQL, then login to get admin token\n3. Set the token in the collection variable 'adminToken'\n4. Register users, they all start as CITIZEN\n5. Admin changes roles via PATCH /api/users/{id}/change-role",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8080" },
    { "key": "adminToken",    "value": "PASTE_ADMIN_JWT_HERE" },
    { "key": "citizenToken",  "value": "PASTE_CITIZEN_JWT_HERE" },
    { "key": "lawyerToken",   "value": "PASTE_LAWYER_JWT_HERE" },
    { "key": "judgeToken",    "value": "PASTE_JUDGE_JWT_HERE" },
    { "key": "clerkToken",    "value": "PASTE_CLERK_JWT_HERE" },
    { "key": "userId",        "value": "1" },
    { "key": "citizenId",     "value": "1" },
    { "key": "caseId",        "value": "1" },
    { "key": "hearingId",     "value": "1" },
    { "key": "judgmentId",    "value": "1" },
    { "key": "documentId",    "value": "1" }
  ],
  "item": [

    {
      "name": "01 — Authentication",
      "item": [
        {
          "name": "Register (all users start as CITIZEN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Citizen\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9999999999\"\n}"
            },
            "description": "Register a new user. Role is always CITIZEN by default. Admin must change role after registration.\n\nNO role field needed — if you send role it is ignored."
          }
        },
        {
          "name": "Register — Lawyer (starts as CITIZEN, admin promotes)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rahul Sharma\",\n  \"email\": \"rahul.lawyer@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"8888888888\"\n}"
            },
            "description": "Register a lawyer. They start as CITIZEN. Admin then uses PATCH /api/users/{id}/change-role to make them LAWYER."
          }
        },
        {
          "name": "Register — Judge (starts as CITIZEN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Justice Ramesh Kumar\",\n  \"email\": \"judge@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"7777777777\"\n}"
            }
          }
        },
        {
          "name": "Register — Clerk (starts as CITIZEN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Clerk Priya\",\n  \"email\": \"clerk@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"6666666666\"\n}"
            }
          }
        },
        {
          "name": "Login — Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@justiceserve.com\",\n  \"password\": \"admin@123\"\n}"
            },
            "description": "Admin is created via SQL INSERT. Copy the token from response and paste into collection variable 'adminToken'."
          }
        },
        {
          "name": "Login — Citizen",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login — Lawyer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rahul.lawyer@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login — Judge",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"judge@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login — Clerk",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"clerk@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "02 — User Management (Admin only)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api","users"] },
            "description": "Returns all users. Admin only."
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}"] }
          }
        },
        {
          "name": "Get Users By Role — LAWYER",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/role/LAWYER", "host": ["{{baseUrl}}"], "path": ["api","users","role","LAWYER"] },
            "description": "Available roles: CITIZEN, LAWYER, JUDGE, CLERK, ADMIN, COMPLIANCE, AUDITOR"
          }
        },
        {
          "name": "Get Users By Role — JUDGE",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/role/JUDGE", "host": ["{{baseUrl}}"], "path": ["api","users","role","JUDGE"] }
          }
        },
        {
          "name": "Get Users By Role — CITIZEN",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/role/CITIZEN", "host": ["{{baseUrl}}"], "path": ["api","users","role","CITIZEN"] }
          }
        },
        {
          "name": "Change User Role → LAWYER",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/change-role", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","change-role"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"LAWYER\"\n}"
            },
            "description": "Change a user's role. User must log out and log back in after this.\n\nAvailable roles:\n- CITIZEN\n- LAWYER\n- JUDGE\n- CLERK\n- ADMIN\n- COMPLIANCE\n- AUDITOR"
          }
        },
        {
          "name": "Change User Role → JUDGE",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/change-role", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","change-role"] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"JUDGE\"\n}" }
          }
        },
        {
          "name": "Change User Role → CLERK",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/change-role", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","change-role"] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"CLERK\"\n}" }
          }
        },
        {
          "name": "Change User Role → COMPLIANCE",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/change-role", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","change-role"] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"COMPLIANCE\"\n}" }
          }
        },
        {
          "name": "Change User Role → AUDITOR",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/change-role", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","change-role"] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"AUDITOR\"\n}" }
          }
        },
        {
          "name": "Change User Role → CITIZEN (demote)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}/change-role", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","change-role"] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"CITIZEN\"\n}" }
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}/status?status=INACTIVE",
              "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","status"],
              "query": [{ "key": "status", "value": "INACTIVE" }]
            }
          }
        },
        {
          "name": "Activate User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}/status?status=ACTIVE",
              "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}","status"],
              "query": [{ "key": "status", "value": "ACTIVE" }]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","users","{{userId}}"] }
          }
        }
      ]
    },

    {
      "name": "03 — Citizen Profile",
      "item": [
        {
          "name": "Create Citizen Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{citizenToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/citizens", "host": ["{{baseUrl}}"], "path": ["api","citizens"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 2,\n  \"name\": \"John Citizen\",\n  \"dob\": \"1990-05-15\",\n  \"gender\": \"Male\",\n  \"address\": \"123 Main Street, Chennai, Tamil Nadu\",\n  \"contactInfo\": \"+91 9999999999\"\n}"
            }
          }
        },
        {
          "name": "Get All Citizens",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/citizens", "host": ["{{baseUrl}}"], "path": ["api","citizens"] }
          }
        },
        {
          "name": "Get Citizen By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{citizenToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/citizens/{{citizenId}}", "host": ["{{baseUrl}}"], "path": ["api","citizens","{{citizenId}}"] }
          }
        },
        {
          "name": "Get Citizen By User ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{citizenToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/citizens/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","citizens","user","{{userId}}"] }
          }
        },
        {
          "name": "Update Citizen Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{citizenToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/citizens/{{citizenId}}", "host": ["{{baseUrl}}"], "path": ["api","citizens","{{citizenId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 2,\n  \"name\": \"John Citizen Updated\",\n  \"dob\": \"1990-05-15\",\n  \"gender\": \"Male\",\n  \"address\": \"456 New Street, Chennai\",\n  \"contactInfo\": \"+91 8888888888\"\n}"
            }
          }
        },
        {
          "name": "Add Citizen Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{citizenToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/citizens/{{citizenId}}/documents", "host": ["{{baseUrl}}"], "path": ["api","citizens","{{citizenId}}","documents"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"docType\": \"ID_PROOF\",\n  \"fileUri\": \"https://drive.google.com/file/d/your-file-id\"\n}"
            },
            "description": "docType options: PETITION, EVIDENCE, ORDER, ID_PROOF, LEGAL_DOC"
          }
        },
        {
          "name": "Add Citizen Document — LEGAL_DOC",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{citizenToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/citizens/{{citizenId}}/documents", "host": ["{{baseUrl}}"], "path": ["api","citizens","{{citizenId}}","documents"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"docType\": \"LEGAL_DOC\",\n  \"fileUri\": \"https://drive.google.com/file/d/your-legal-doc-id\"\n}"
            }
          }
        },
        {
          "name": "Get Citizen Documents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{citizenToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/citizens/{{citizenId}}/documents", "host": ["{{baseUrl}}"], "path": ["api","citizens","{{citizenId}}","documents"] }
          }
        },
        {
          "name": "Verify Citizen Document — VERIFIED (Clerk)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{clerkToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/citizens/{{citizenId}}/documents/{{documentId}}/verify?status=VERIFIED",
              "host": ["{{baseUrl}}"], "path": ["api","citizens","{{citizenId}}","documents","{{documentId}}","verify"],
              "query": [{ "key": "status", "value": "VERIFIED" }]
            }
          }
        },
        {
          "name": "Verify Citizen Document — REJECTED (Clerk)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{clerkToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/citizens/{{citizenId}}/documents/{{documentId}}/verify?status=REJECTED",
              "host": ["{{baseUrl}}"], "path": ["api","citizens","{{citizenId}}","documents","{{documentId}}","verify"],
              "query": [{ "key": "status", "value": "REJECTED" }]
            }
          }
        }
      ]
    },

    {
      "name": "04 — Case Filing & Management",
      "item": [
        {
          "name": "File New Case — No Lawyer (Clerk assigns later)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{citizenToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/cases", "host": ["{{baseUrl}}"], "path": ["api","cases"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"citizenId\": 1,\n  \"title\": \"Property Dispute — John vs State\",\n  \"description\": \"Disputed land ownership in Survey No. 45, Chennai\"\n}"
            },
            "description": "No lawyerId — clerk will assign lawyer later via assign-lawyer endpoint.\nNotification sent to all clerks automatically."
          }
        },
        {
          "name": "File New Case — With Lawyer (citizen knows lawyer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{citizenToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/cases", "host": ["{{baseUrl}}"], "path": ["api","cases"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"citizenId\": 1,\n  \"lawyerId\": 3,\n  \"title\": \"Divorce Proceedings — Jane Doe\",\n  \"description\": \"Mutual divorce filing under Section 13B\"\n}"
            },
            "description": "Citizen already knows the lawyer — lawyer gets notified immediately at filing time. No clerk assignment needed."
          }
        },
        {
          "name": "Get All Cases",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/cases", "host": ["{{baseUrl}}"], "path": ["api","cases"] }
          }
        },
        {
          "name": "Get Case By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{citizenToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/cases/{{caseId}}", "host": ["{{baseUrl}}"], "path": ["api","cases","{{caseId}}"] }
          }
        },
        {
          "name": "Get Cases By Citizen",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{citizenToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/cases/citizen/{{citizenId}}", "host": ["{{baseUrl}}"], "path": ["api","cases","citizen","{{citizenId}}"] }
          }
        },
        {
          "name": "Get Cases By Lawyer",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{lawyerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/cases/lawyer/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","cases","lawyer","{{userId}}"] }
          }
        },
        {
          "name": "Get Cases By Status — FILED",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clerkToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/cases/status/FILED", "host": ["{{baseUrl}}"], "path": ["api","cases","status","FILED"] },
            "description": "Status options: FILED, UNDER_REVIEW, ACTIVE, HEARING_SCHEDULED, JUDGMENT_PENDING, CLOSED, DISMISSED"
          }
        },
        {
          "name": "Assign Lawyer to Case (Clerk/Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{clerkToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{caseId}}/assign-lawyer?lawyerId=3",
              "host": ["{{baseUrl}}"], "path": ["api","cases","{{caseId}}","assign-lawyer"],
              "query": [{ "key": "lawyerId", "value": "3" }]
            },
            "description": "Assigns a lawyer to the case. Automatically sends notification to:\n- The assigned lawyer\n- The citizen"
          }
        },
        {
          "name": "Assign Judge to Case (Clerk/Admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{clerkToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{caseId}}/assign-judge?judgeId=4",
              "host": ["{{baseUrl}}"], "path": ["api","cases","{{caseId}}","assign-judge"],
              "query": [{ "key": "judgeId", "value": "4" }]
            },
            "description": "Assigns a judge to the case. Automatically sends notification to the judge."
          }
        },
        {
          "name": "Update Case Status — UNDER_REVIEW",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{clerkToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{caseId}}/status?status=UNDER_REVIEW",
              "host": ["{{baseUrl}}"], "path": ["api","cases","{{caseId}}","status"],
              "query": [{ "key": "status", "value": "UNDER_REVIEW" }]
            }
          }
        },
        {
          "name": "Update Case Status — ACTIVE",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{clerkToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cases/{{caseId}}/status?status=ACTIVE",
              "host": ["{{baseUrl}}"], "path": ["api","cases","{{caseId}}","status"],
              "query": [{ "key": "status", "value": "ACTIVE" }]
            }
          }
        },
        {
          "name": "Update Case Status — DISMISSED",
          "request": {
